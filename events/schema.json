{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/XARKUR/qubic-history/events/schema.json",
  "title": "Qubic Custom Events",
  "type": "object",
  "required": ["schemaVersion", "events"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "qubic-custom-events-v1"
    },
    "updatedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/event"
      }
    }
  },
  "$defs": {
    "event": {
      "type": "object",
      "required": [
        "id",
        "title",
        "summary",
        "category",
        "importance",
        "status",
        "date",
        "sources"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{5,120}$"
        },
        "title": {
          "type": "string",
          "minLength": 3,
          "maxLength": 140
        },
        "summary": {
          "type": "string",
          "minLength": 3,
          "maxLength": 500
        },
        "category": {
          "enum": [
            "ecosystem",
            "release",
            "exchange",
            "incident",
            "network",
            "mining",
            "qearn",
            "governance",
            "community",
            "other"
          ]
        },
        "importance": {
          "enum": ["major", "normal", "minor"]
        },
        "status": {
          "enum": ["draft", "confirmed", "archived", "estimated"]
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "endDate": {
          "type": "string",
          "format": "date"
        },
        "epoch": {
          "type": "integer",
          "minimum": 1
        },
        "chartMarker": {
          "type": "boolean",
          "default": true
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/source"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40
          },
          "uniqueItems": true
        },
        "notes": {
          "type": "string",
          "maxLength": 1000
        }
      }
    },
    "source": {
      "type": "object",
      "required": ["label", "url", "type"],
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "minLength": 2,
          "maxLength": 80
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "archivedUrl": {
          "type": "string",
          "format": "uri"
        },
        "type": {
          "enum": [
            "official",
            "github",
            "social",
            "explorer",
            "community",
            "screenshot",
            "other"
          ]
        }
      }
    }
  }
}
